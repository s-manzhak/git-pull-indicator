{
  "name": "git-pull-indicator",
  "displayName": "Git Pull Indicator",
  "description": "Shows Git pull/push badges on repository folders in the Explorer",
  "version": "0.1.28",
  "publisher": "zhakman",
  "license": "MIT",
  "homepage": "https://marketplace.visualstudio.com/items?itemName=zhakman.git-pull-indicator",
  "bugs": {
    "url": "https://github.com/s-manzhak/git-pull-indicator/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/s-manzhak/git-pull-indicator.git"
  },
  "keywords": [
    "git",
    "pull",
    "push",
    "explorer",
    "badge",
    "monorepo",
    "multi-root"
  ],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/.git"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitPullIndicator.refresh",
        "title": "Git Pull Indicator: Refresh"
      },
      {
        "command": "gitPullIndicator.fetchAll",
        "title": "Git Pull Indicator: Fetch All"
      },
      {
        "command": "gitPullIndicator.openRepositoryTerminal",
        "title": "Git Pull Indicator: Open Repository Terminal"
      },
      {
        "command": "gitPullIndicator.showLog",
        "title": "Git Pull Indicator: Show Log"
      },
      {
        "command": "gitPullIndicator.focusView",
        "title": "Git Pull Indicator: Show Git Pull Push Panel"
      },
      {
        "command": "gitPullIndicator.revealRepository",
        "title": "Git Pull Indicator: Reveal Repository in Explorer"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "gitPullIndicator.statusView",
          "name": "Git Pull Push",
          "when": "workspaceFolderCount != 0"
        }
      ]
    },
    "configurationDefaults": {
      "explorer.decorations.badges": true,
      "explorer.decorations.colors": true
    },
    "configuration": {
      "type": "object",
      "title": "Git Pull Indicator",
      "properties": {
        "gitPullIndicator.refreshIntervalMinutes": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Auto-refresh all repos every N minutes (backup if live watchers miss a commit)"
        },
        "gitPullIndicator.autoFetch": {
          "type": "boolean",
          "default": false,
          "description": "After first status pass, run git fetch in background (slow with many repos)"
        },
        "gitPullIndicator.maxDepth": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "description": "Maximum depth to search for .git folders inside workspace"
        },
        "gitPullIndicator.statusConcurrency": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 8,
          "description": "Maximum number of repositories checked at the same time"
        },
        "gitPullIndicator.showCleanRepositories": {
          "type": "boolean",
          "default": false,
          "description": "Show a checkmark badge for up-to-date repositories"
        },
        "gitPullIndicator.useAsciiBadges": {
          "type": "boolean",
          "default": false,
          "description": "Use PL/PS/PM text instead of Unicode arrows"
        },
        "gitPullIndicator.showExplorerFolderBadges": {
          "type": "boolean",
          "default": true,
          "description": "Show ↓/↑/↕ badge to the right of each git repo folder name in Explorer (repo root only, not files inside)"
        },
        "gitPullIndicator.showExplorerFolderColors": {
          "type": "boolean",
          "default": true,
          "description": "Color git repo folder names by sync state in Explorer when badges are hidden by built-in Git decorations"
        },
        "gitPullIndicator.refreshOnWindowFocus": {
          "type": "boolean",
          "default": false,
          "description": "Refresh all repositories when Cursor regains focus. Disabled by default to reduce CPU usage in large workspaces"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "install:local": "bash scripts/install-local.sh",
    "debug:host": "bash scripts/open-debug-host.sh",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}

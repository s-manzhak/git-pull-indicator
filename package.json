{
  "name": "git-pull-indicator",
  "displayName": "Git Pull Indicator",
  "description": "Shows Git remote status badges on repository folders in the Explorer",
  "version": "0.1.0",
  "publisher": "zhakman",
  "license": "MIT",
  "homepage": "https://marketplace.visualstudio.com/items?itemName=zhakman.git-pull-indicator",
  "bugs": {
    "url": "https://github.com/zhakman/git-pull-indicator/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zhakman/git-pull-indicator.git"
  },
  "keywords": [
    "git",
    "pull",
    "push",
    "explorer",
    "badge",
    "monorepo",
    "multi-root"
  ],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitPullIndicator.refresh",
        "title": "Git Pull Indicator: Refresh"
      },
      {
        "command": "gitPullIndicator.fetchAll",
        "title": "Git Pull Indicator: Fetch All"
      },
      {
        "command": "gitPullIndicator.openRepositoryTerminal",
        "title": "Git Pull Indicator: Open Repository Terminal"
      },
      {
        "command": "gitPullIndicator.showLog",
        "title": "Git Pull Indicator: Show Log"
      },
      {
        "command": "gitPullIndicator.focusView",
        "title": "Git Pull Indicator: Show Repositories Panel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "git-pull-indicator",
          "title": "Git Pull",
          "icon": "resources/git-pull-icon.svg"
        }
      ]
    },
    "views": {
      "git-pull-indicator": [
        {
          "id": "gitPullIndicator.statusView",
          "name": "Repositories"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Git Pull Indicator",
      "properties": {
        "gitPullIndicator.refreshIntervalMinutes": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "description": "Auto-refresh all repos every N minutes (backup if live watchers miss a commit)"
        },
        "gitPullIndicator.autoFetch": {
          "type": "boolean",
          "default": false,
          "description": "After first status pass, run git fetch in background (slow with many repos)"
        },
        "gitPullIndicator.maxDepth": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "description": "Maximum depth to search for .git folders inside workspace"
        },
        "gitPullIndicator.showCleanRepositories": {
          "type": "boolean",
          "default": false,
          "description": "Show a checkmark badge for up-to-date repositories"
        },
        "gitPullIndicator.useAsciiBadges": {
          "type": "boolean",
          "default": false,
          "description": "Use PL/PS/PM text badges instead of Unicode arrows (if badges do not show in Explorer)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "install:local": "bash scripts/install-local.sh",
    "debug:host": "bash scripts/open-debug-host.sh",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
